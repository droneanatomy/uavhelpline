# Copy this file to .env.local and fill in your Supabase project values.
# Leave these blank and the site runs in file mode (Markdown), no backend needed.

# ---- Site / SEO ----
# Canonical origin used for sitemap.xml, robots.txt, and OG metadata.
# In production set this to your domain (e.g. https://uavhelpline.com).
NEXT_PUBLIC_SITE_URL=

# ---- Newsletter (Brevo) ----
# Brevo API key (SECRET, server-only). /api/subscribe adds the contact to Brevo
# when this is set; leave blank and the form accepts the email gracefully.
# Also used by the weekly newsletter script to create the draft campaign.
BREVO_API_KEY=
# Numeric Brevo list ID — subscribers are added here and the weekly campaign
# targets this list.
BREVO_LIST_ID=
# Weekly campaign sender — must be a VERIFIED sender in Brevo.
BREVO_SENDER_EMAIL=info.uavhelpline@gmail.com
BREVO_SENDER_NAME=UAVHelpline
# NOTE: the /newsletter form sends FIRSTNAME (name), INDUSTRY (area of interest),
# LINKEDIN (optional), and ABOUT (optional). Create custom contact attributes
# INDUSTRY, LINKEDIN, and ABOUT (type Text) in Brevo → Contacts → Settings →
# Contact attributes, or the API rejects them.

# ---- Analytics ----
# Vercel Web Analytics needs no key (toggle it on in the Vercel dashboard).
# Google Analytics 4: paste your Measurement ID (looks like G-XXXXXXXXXX).
# Leave blank and the GA script simply isn't injected.
NEXT_PUBLIC_GA_ID=

# ---- Daily AI flow (Vercel Cron → /api/cron) ----
# Required for the scheduled run. Vercel sends this as a Bearer token; the
# endpoint rejects requests without it. Use a long random string.
CRON_SECRET=

# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SECRET — server only, never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Morning engine (scripts/morning-research.mjs) ----
# Leave ANTHROPIC_API_KEY blank and the engine writes a labeled placeholder
# draft (the pipeline still runs). Set it and Claude researches each story on
# the web, confirms the facts, and writes the draft in the UAVHelpline voice.
ANTHROPIC_API_KEY=
# Optional overrides:
UAVHELPLINE_DRAFT_MODEL=claude-sonnet-4-6
UAVHELPLINE_RECENCY_DAYS=3
# Max cited sources per post (primary-first, curated). Default 5.
UAVHELPLINE_MAX_SOURCES=5

# ---- Hero image generation (editorial illustration) ----
# Provider options: "cloudflare" (free daily tier, reliable from servers),
# "pollinations" (free, no key, but rate-gated from datacenter IPs),
# "fal" (FAL_KEY), "gemini" (GEMINI_API_KEY, needs billing).
# Any failure falls back to the branded SVG, so this is safe to leave as-is.
UAVHELPLINE_IMAGE_PROVIDER=cloudflare
# Cloudflare Workers AI (free daily allowance): token + account id from the CF dashboard.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Other providers (optional):
FAL_KEY=
GEMINI_API_KEY=
# Pollinations is free but rate-gates datacenter/server IPs; a free token
# (from auth.pollinations.ai) lifts the limit. Leave blank to try anonymous.
POLLINATIONS_TOKEN=
# Optional model overrides:
# UAVHELPLINE_POLLINATIONS_MODEL=flux
# UAVHELPLINE_FAL_MODEL=fal-ai/flux/schnell
# UAVHELPLINE_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
